{
  "name": "pi-web-sidebar",
  "version": "0.1.9",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/index.ts --outfile index.js --target browser --format esm --sourcemap=none --minify",
    "test": "bun test",
    "validate": "bun ./scripts/validate.js",
    "build:backend": "./scripts/build-backends.sh",
    "check": "bun run build && bun run typecheck && bun test && bun run validate",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "happy-dom": "20.10.1",
    "typescript": "^5.9.3",
    "bun-types": "^1.3.10"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "browser-whisper": "^1.0.2",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.2.6"
  }
}
