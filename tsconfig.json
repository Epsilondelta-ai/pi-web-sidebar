{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "entry.test.ts", "index.test.ts", "index.d.ts", "test-globals.d.ts"]
}
